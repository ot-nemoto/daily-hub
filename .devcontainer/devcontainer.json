{
  "name": "Node.js & TypeScript",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  // コンテナ作成後に依存関係をインストール・Playwright ブラウザをセットアップ
  "postCreateCommand": "npm install && npx playwright install --with-deps chromium",

  "customizations": {
    "vscode": {
      // エディタ設定は .vscode/settings.json で管理
      "extensions": [
        // Biome（lint / format）
        "biomejs.biome",
        // Prisma スキーマのシンタックスハイライト・補完
        "Prisma.prisma",
        // Tailwind CSS クラス補完
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
